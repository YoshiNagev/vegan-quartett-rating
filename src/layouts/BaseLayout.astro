---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Vegan Quartett Rating" } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Bewerte Veganismus-Argumente nach Verbreitung, Komplexität und Trigger."
    />
  </head>
  <body>
    <slot />
  </body>
</html>