---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getRandomHydratedPrompt } from "../lib/prompt";

const { prompt, argument, metric } = getRandomHydratedPrompt();
---

<BaseLayout title="Bewerten">
  <main class="container">
    <section class="rating-page">
      <div class="page-head">
        <a class="back-link" href="/">← Zur Startseite</a>
        <p class="eyebrow">Eine zufällige Einzelbewertung</p>
      </div>

      <article class="rating-card animated-card" id="ratingCard">
        <div class="rating-meta">
          <span class="pill">{argument.categoryGroup}</span>
          <span class="pill pill-accent">{metric.name}</span>
        </div>

        <h1>{metric.name}</h1>
        <p class="question">{metric.question}</p>

        <blockquote class="argument-box">
          {argument.text}
        </blockquote>

        <form id="ratingForm" class="rating-form">
          <input type="hidden" name="promptId" value={prompt.id} />
          <input type="hidden" name="argumentId" value={argument.id} />
          <input type="hidden" name="metricId" value={metric.id} />
          <input type="hidden" name="responseType" id="responseType" value="rated" />

          <div class="slider-card">
            <label for="sliderValue" class="slider-label">Deine Einschätzung</label>

            <input
              id="sliderValue"
              name="sliderValue"
              type="range"
              min="0"
              max="100"
              value="50"
              class="slider-input"
            />

            <div class="range-labels">
              <span>{metric.leftLabel}</span>
              <span>{metric.rightLabel}</span>
            </div>
          </div>

          <div class="submit-row">
            <button type="submit" class="button button-primary" id="submitButton">
              Bewertung absenden
            </button>
          </div>

          <div class="secondary-actions">
            <button type="button" onclick="submitSpecial('unknown')">
              Kenne ich nicht
            </button>
            <button type="button" onclick="submitSpecial('skipped')">
              Überspringen
            </button>
          </div>
        </form>
      </article>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  const form = document.getElementById("ratingForm");
  const card = document.getElementById("ratingCard");
  const responseTypeInput = document.getElementById("responseType");
  const submitButton = document.getElementById("submitButton");

  let isSubmitting = false;

  async function sendForm(responseType = "rated") {
    if (!form || !card || !responseTypeInput || isSubmitting) return;

    isSubmitting = true;
    responseTypeInput.value = responseType;

    if (submitButton) {
      submitButton.setAttribute("disabled", "disabled");
      submitButton.textContent = "Wird gesendet...";
    }

    const formData = new FormData(form);

    try {
      const response = await fetch("/api/submit-rating", {
        method: "POST",
        body: formData,
      });

      if (!response.ok) {
        throw new Error("Request failed");
      }

      if (responseType === "rated") {
        card.classList.add("swipe-out-left");
      } else if (responseType === "unknown") {
        card.classList.add("swipe-out-up");
      } else {
        card.classList.add("swipe-out-right");
      }

      setTimeout(() => {
        window.location.href = "/rate";
      }, 320);
    } catch (error) {
      console.error(error);
      isSubmitting = false;

      if (submitButton) {
        submitButton.removeAttribute("disabled");
        submitButton.textContent = "Bewertung absenden";
      }

      alert("Beim Speichern ist ein Fehler aufgetreten.");
    }
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    await sendForm("rated");
  });

  async function submitSpecial(type) {
    await sendForm(type);
  }

  window.submitSpecial = submitSpecial;
</script>