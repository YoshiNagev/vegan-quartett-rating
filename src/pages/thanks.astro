---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Danke">
  <main class="container">
    <section class="info-card">
      <p class="eyebrow">Danke</p>
      <h1>Deine Antwort wurde gespeichert.</h1>
      <p>
        Du kannst direkt mit der nächsten zufälligen Bewertung weitermachen.
      </p>

      <div class="actions">
        <a class="button button-primary" href="/rate">Nächstes Argument</a>
        <a class="button" href="/">Zur Startseite</a>
      </div>
    </section>
  </main>
</BaseLayout>