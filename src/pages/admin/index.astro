---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Admin">
  <main class="container">
    <section class="info-card">
      <p class="eyebrow">Admin</p>
      <h1>Verwaltung & Auswertung</h1>
      <p>
        Hier kannst du Rohdaten ansehen, Auswertungen prüfen und die Daten als
        CSV exportieren.
      </p>

      <div class="admin-links">
        <a class="button button-primary" href="/admin/responses">Rohdaten ansehen</a>
        <a class="button" href="/admin/scores">Auswertung ansehen</a>
        <a class="button" href="/api/export-csv">CSV exportieren</a>
      </div>
    </section>
  </main>
</BaseLayout>