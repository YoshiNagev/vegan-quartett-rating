{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/responses/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/scores/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin-summary/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/export-csv/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/next-prompt/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/submit-rating/?$",
			"dest": "_render"
		},
		{
			"src": "^/rate/?$",
			"dest": "_render"
		},
		{
			"src": "^/thanks/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}