---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllResponses } from "../../lib/db";
import { summarizeResponses } from "../../lib/scoring";
import { getArgumentTextById, getMetricNameById } from "../../lib/admin";

const responses = await getAllResponses();
const summary = summarizeResponses(responses);

const summaryWithLabels = summary.map((item) => ({
  ...item,
  argumentText: getArgumentTextById(item.argumentId),
  metricName: getMetricNameById(item.metricId),
}));
---

<BaseLayout title="Auswertung">
  <main class="container">
    <section class="admin-section">
      <div class="admin-head">
        <a class="back-link" href="/admin">← Zurück zum Admin-Bereich</a>
        <h1>Auswertung</h1>
        <p>{summaryWithLabels.length} Prompt-Zusammenfassungen</p>
      </div>

      {summaryWithLabels.length === 0 ? (
        <div class="empty-state">
          <p>Noch keine Daten zur Auswertung vorhanden.</p>
        </div>
      ) : (
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Argument-ID</th>
                <th>Argument</th>
                <th>Kategorie</th>
                <th>Gesamt</th>
                <th>Rated</th>
                <th>Unknown</th>
                <th>Skipped</th>
                <th>Durchschnitt</th>
              </tr>
            </thead>
            <tbody>
              {summaryWithLabels.map((item) => (
                <tr>
                  <td>{item.argumentId}</td>
                  <td>{item.argumentText}</td>
                  <td>{item.metricName}</td>
                  <td>{item.total}</td>
                  <td>{item.ratedCount}</td>
                  <td>{item.unknownCount}</td>
                  <td>{item.skippedCount}</td>
                  <td>{item.average ?? "—"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </main>
</BaseLayout>